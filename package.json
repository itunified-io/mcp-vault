{
  "name": "vault-mcp",
  "mcpName": "io.github.itunified-io/vault",
  "version": "2026.3.16",
  "description": "Secure MCP access for HashiCorp Vault — 28 tools for secrets, policies, auth methods, tokens, and system health via Vault HTTP API",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server.js",
    "./types": "./dist/types.js",
    "./client/*": "./dist/client/*.js",
    "./utils/*": "./dist/utils/*.js",
    "./transport": "./dist/transport.js"
  },
  "bin": {
    "mcp-vault": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test && node scripts/prepublish-check.js"
  },
  "keywords": [
    "mcp",
    "vault",
    "hashicorp",
    "secrets",
    "model-context-protocol",
    "ai",
    "infrastructure"
  ],
  "author": "itunified.io",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itunified-io/mcp-vault.git"
  },
  "bugs": {
    "url": "https://github.com/itunified-io/mcp-vault/issues"
  },
  "homepage": "https://github.com/itunified-io/mcp-vault#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "axios": "^1.7.0",
    "express": "^5.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
