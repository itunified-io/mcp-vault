# Vault connection
VAULT_ADDR=http://127.0.0.1:8200

# Auth: Token (simplest — for dev/operator use)
VAULT_TOKEN=hvs.your-token-here

# Auth: Kubernetes (for in-cluster pods)
# VAULT_K8S_ROLE=your-role-name
# VAULT_K8S_MOUNT_PATH=kubernetes

# Auth: AppRole (for CI/automation)
# VAULT_APPROLE_ROLE_ID=your-role-id
# VAULT_APPROLE_SECRET_ID=your-secret-id
# VAULT_APPROLE_MOUNT_PATH=approle

# Optional
# VAULT_NAMESPACE=admin
# VAULT_KV_MOUNT=kv
# VAULT_TIMEOUT=30000
# VAULT_TLS_SKIP_VERIFY=false

# Transport: stdio (default) or sse
# VAULT_MCP_TRANSPORT=stdio
# VAULT_MCP_AUTH_TOKEN=your-mcp-auth-token
# VAULT_MCP_PORT=3000
# VAULT_MCP_HOST=localhost
